  previousCompanies String[] // Notable prior roles
  createdAt         DateTime       @default(now())

  @@index([companyId])
  @@index([name])
}

model MergerAcquisition {
  id         String          @id @default(cuid())
  acquirerId String
  acquirer   CompanyProfile  @relation("acquirer", fields: [acquirerId], references: [id], onDelete: Cascade)
  targetId   String?
  target     CompanyProfile? @relation("target", fields: [targetId], references: [id])
  targetName String // Always store name (target may not be in our DB)
  date       DateTime?
  price      Float? // In USD
  currency   String          @default("USD")
  dealType   String? // "acquisition", "merger", "asset_purchase", "spac"
  status     String          @default("completed") // "announced", "pending", "completed", "terminated"
  rationale  String?         @db.Text
  source     String?
  sourceUrl  String?
  createdAt  DateTime        @default(now())

  @@index([acquirerId])
  @@index([targetId])
  @@index([date])
}

model Partnership {
  id            String          @id @default(cuid())
  companyId     String
  company       CompanyProfile  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partnerId     String?
  partner       CompanyProfile? @relation("partner", fields: [partnerId], references: [id])
  partnerName   String // Always store name
  type          String? // "joint_venture", "strategic_alliance", "supply_agreement", "licensing", "research"
  description   String?         @db.Text
  announcedDate DateTime?
  endDate       DateTime?
  value         Float?
  source        String?
  createdAt     DateTime        @default(now())

  @@index([companyId])
  @@index([partnerId])
}

model SECFiling {
  id              String         @id @default(cuid())
  companyId       String
  company         CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  filingType      String // "10-K", "10-Q", "8-K", "S-1", "DEF 14A"
  filingDate      DateTime
  periodEnd       DateTime?
  description     String?        @db.Text
  edgarUrl        String?
  accessionNumber String?        @unique
  highlights      Json? // Key extracted data points
  createdAt       DateTime       @default(now())

  @@index([companyId])
  @@index([filingType])
  @@index([filingDate])
}

model CompetitiveMapping {
  id           String         @id @default(cuid())
  companyId    String
  company      CompanyProfile @relation("company", fields: [companyId], references: [id], onDelete: Cascade)
  competitorId String
  competitor   CompanyProfile @relation("competitor", fields: [competitorId], references: [id], onDelete: Cascade)
  segment      String? // "small_launch", "LEO_broadband", "earth_observation"
  relationship String? // "direct", "indirect", "potential"
  notes        String?        @db.Text
  createdAt    DateTime       @default(now())

  @@unique([companyId, competitorId, segment])
  @@index([companyId])
  @@index([competitorId])
}

model GovernmentContractAward {
  id                     String          @id @default(cuid())
  companyId              String?
  company                CompanyProfile? @relation(fields: [companyId], references: [id])
  companyName            String
  contractNumber         String?         @unique
  agency                 String // "NASA", "Space Force", "NRO", "NOAA"
  title                  String
  description            String?         @db.Text
  awardDate              DateTime?
  value                  Float?
  ceiling                Float? // Max potential value
  type                   String? // "firm_fixed_price", "cost_plus", "idiq", "bpa"
  naicsCode              String?
  setAside               String? // "small_business", "8a", "hubzone", "wosb", "none"
  performancePeriodStart DateTime?
  performancePeriodEnd   DateTime?
  placeOfPerformance     String?
  samOpportunityId       String?
  source                 String?
  // Competition intelligence fields (from SAM.gov Awards API)
  numberOfOffers         Int? // How many companies bid
  extentCompeted         String? // "Full and Open", "Not Competed", "Set-Aside", etc.
  competitionType        String? // "Full and Open Competition", "Not Available for Competition"
  pscCode                String? // Product/Service Code
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([companyId])
  @@index([agency])
  @@index([awardDate])
  @@index([naicsCode])
}

// ============================================================
// Funding Opportunity Aggregator
// ============================================================

model IntroductionRequest {
  id              String   @id @default(cuid())
  fromUserId      String
  toUserId        String
  aboutUserId     String
  message         String   @db.Text
  status          String   @default("pending") // pending, accepted, declined, completed
  responseMessage String?  @db.Text
  requestedAt     DateTime @default(now())
  respondedAt     DateTime?
  completedAt     DateTime?

  @@unique([fromUserId, toUserId, aboutUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([aboutUserId])
  @@index([status])
}

model ComplianceProgress {
  id             String   @id @default(cuid())
  userId         String
  companyId      String? // Optional — company-scoped progress
  completedItems String[] // Array of checklist item IDs that are checked
  customItems    Json? // User-added custom checklist items
  lastUpdatedAt  DateTime @default(now())
  createdAt      DateTime @default(now())

  @@unique([userId, companyId])
  @@index([userId])
}

model CaseStudy {
  id          String         @id @default(cuid())
  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  slug        String         @unique
  summary     String         @db.Text
  content     String         @db.Text
  clientName  String?
  sector      String?
  metrics     Json? // { outcome, duration, budget, roi, etc. }
  imageUrl    String?
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([companyId])
  @@index([isPublished])
}

model MeetingRequest {
  id             String         @id @default(cuid())
  companyId      String
  company        CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  visitorName    String
  visitorEmail   String
  visitorCompany String?
  message        String         @db.Text
  preferredDate  DateTime?
  status         String         @default("pending") // pending, accepted, declined, completed
  respondedAt    DateTime?
  createdAt      DateTime       @default(now())

  @@index([companyId])
  @@index([status])
}

model BDOpportunity {
  id                  String          @id @default(cuid())
  companyId           String
  company             CompanyProfile  @relation("BDOpportunities", fields: [companyId], references: [id], onDelete: Cascade)
  ownerUserId         String
  owner               User            @relation("BDOpportunities", fields: [ownerUserId], references: [id], onDelete: Cascade)
  // Opportunity metadata
  title               String
  description         String?         @db.Text
  opportunityType     String          @default("procurement") // procurement, partnership, funding, teaming, contract_renewal, sbir
  externalId          String? // Link to SAM.gov noticeId, SBIR award, etc.
  // Classification
  agency              String? // NASA, Space Force, NRO, NOAA, etc.
  naicsCode           String?
  category            String? // launch, satellite, ground, propulsion, etc.
  valueEstimated      Float? // Estimated deal size
  // Compliance
  itarRequired        Boolean         @default(false)
  clearanceRequired   String? // none, secret, top_secret, ts_sci
  setAsideEligibility String[] // 8(a), HUBZone, WOSB, SDVOSB
  solicitationNumber  String?
  samUrl              String?
  // Pipeline tracking
  stage               String          @default("discovery") // discovery, pursuit, capture, proposal, submitted, evaluation, award, lost, on_hold
  probability         Int? // 0-100 win probability
  expectedCloseDate   DateTime?
  proposalDeadline    DateTime?
  // Outcome
  wonAmount           Float?
  lostReason          String?
  // Timestamps
  discoveredAt        DateTime        @default(now())
  pursuitStartedAt    DateTime?
  proposalSubmittedAt DateTime?
  awardedAt           DateTime?
  lostAt              DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  // Relations
  interactions        BDInteraction[]

  @@index([companyId])
  @@index([ownerUserId])
  @@index([stage])
  @@index([agency])
  @@index([expectedCloseDate])
}

model BDInteraction {
  id            String        @id @default(cuid())
  opportunityId String
  opportunity   BDOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  type          String // call, email, meeting, site_visit, proposal_draft, proposal_submit, negotiation, teaming, note
  date          DateTime      @default(now())
  title         String?
  notes         String?       @db.Text
  contactName   String?
  contactOrg    String?
  createdAt     DateTime      @default(now())

  @@index([opportunityId, date])
}

model SubawardRelationship {
  id               String    @id @default(cuid())
  primeContractId  String? // Link to GovernmentContractAward if matched
  primeCompanyName String
  primeCompanyId   String? // FK to CompanyProfile if matched
  primeUei         String?
  subCompanyName   String
  subCompanyId     String? // FK to CompanyProfile if matched
  subUei           String?
  subawardAmount   Float?
  subawardDate     DateTime?
  agency           String?
  description      String?   @db.Text
  piid             String? // Prime contract number
  naicsCode        String?
  createdAt        DateTime  @default(now())

  @@index([primeCompanyId])
  @@index([subCompanyId])
  @@index([primeCompanyName])
  @@index([subCompanyName])
  @@index([agency])
}

model SBIRAward {
  id                 String    @id @default(cuid())
  firm               String // Company name
  companyId          String? // FK to CompanyProfile if matched
  awardTitle         String
  agency             String // NASA, SpaceWERX, NOAA, etc.
  phase              String // Phase I, Phase II, Phase III
  program            String // SBIR or STTR
  topicCode          String? // Links competitors on same topic
  awardAmount        Float?
  awardYear          Int?
  proposalAwardDate  DateTime?
  contractEndDate    DateTime?
  solicitationNumber String?
  abstract           String?   @db.Text
  keywords           String[]
  city               String?
  state              String?
  hubzoneOwned       Boolean   @default(false)
  womenOwned         Boolean   @default(false)
  numberOfEmployees  Int?
  createdAt          DateTime  @default(now())

  @@unique([firm, topicCode, phase, awardYear])
  @@index([companyId])
  @@index([agency])
  @@index([topicCode])
  @@index([phase])
  @@index([awardYear])
}

model FundingOpportunity {
  id                 String    @id @default(cuid())
  externalId         String?   @unique // Dedup key: "sbir-12345", "sam-ABC", "grants-XYZ"
  title              String
  description        String?   @db.Text
  agency             String // "NASA", "DARPA", "NSF", "Space Force", "ESA", "FAA"
  program            String? // "SBIR Phase I", "STTR Phase II", "ROSES", "BAA"
  fundingType        String // "grant", "contract", "cooperative_agreement", "sbir", "sttr", "prize"
  amountMin          Float? // Minimum award in USD
  amountMax          Float? // Maximum award in USD
  totalBudget        Float? // Total program budget
  deadline           DateTime?
  openDate           DateTime?
  status             String    @default("open") // "open", "closed", "upcoming", "rolling"
  eligibility        String[] // ["small_business", "university", "nonprofit", "any"]
  setAside           String? // "8a", "hubzone", "wosb", "sdvosb", "none"
  categories         String[] // ["propulsion", "earth_observation", "communications", "launch", "in_space", "defense", "lunar", "debris"]
  applicationUrl     String?
  sourceUrl          String?
  source             String // "sbir.gov", "sam.gov", "grants.gov", "nasa.gov", "manual"
  contactName        String?
  contactEmail       String?
  naicsCode          String?
  solicitationNumber String?
  stateIncentive     Boolean   @default(false) // Is this a state/regional incentive?
  state              String? // For state-level incentives
  recurring          Boolean   @default(false) // Does this open periodically?
  lastUpdated        DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([agency])
  @@index([fundingType])
  @@index([deadline])
  @@index([source])
  @@index([stateIncentive])
  @@index([createdAt])
}

// ============================================================
// Company Intelligence - Extended Models
