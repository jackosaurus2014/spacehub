  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  type        String // "headquarters", "manufacturing", "test_facility", "launch_site", "ground_station", "office", "r_and_d"
  address     String?
  city        String?
  state       String?
  country     String
  latitude    Float?
  longitude   Float?
  employees   Int?
  description String?        @db.Text
  createdAt   DateTime       @default(now())

  @@index([companyId])
  @@index([type])
  @@index([country])
