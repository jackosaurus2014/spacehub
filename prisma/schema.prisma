  noradId         String?
  cosparId        String?
  launchDate      DateTime?
  orbitType       String? // "LEO", "MEO", "GEO", "HEO", "SSO", "Lunar", "Interplanetary"
  orbitAltitudeKm Float?
  inclination     Float?
  status          String          @default("active") // "active", "decommissioned", "failed", "planned", "deorbited"
