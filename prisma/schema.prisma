  @@index([committee])
  @@index([date])
}

model SavedProcurementSearch {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  filters       Json // { agencies, naicsCodes, setAsides, minValue, maxValue, keywords }
  alertEnabled  Boolean   @default(true)
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  matches SavedSearchMatch[]

  @@index([userId])
}

model SavedSearchMatch {
  id            String                 @id @default(cuid())
  searchId      String
  search        SavedProcurementSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   ProcurementOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  isNew         Boolean                @default(true)
  matchedAt     DateTime               @default(now())

  @@unique([searchId, opportunityId])
  @@index([searchId])
  @@index([isNew])
}

// ============================================================
// Personalized Dashboard Builder
// ============================================================

model DashboardLayout {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isPublic    Boolean  @default(false)
  gridColumns Int      @default(12)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  widgets DashboardWidget[]

  @@index([userId])
  @@index([isDefault])
}

model DashboardWidget {
  id         String          @id @default(cuid())
  layoutId   String
  layout     DashboardLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  moduleId   String
  widgetType String
  title      String?
  x          Int             @default(0)
  y          Int             @default(0)
  w          Int             @default(6)
  h          Int             @default(4)
  minW       Int             @default(3)
  minH       Int             @default(2)
  config     Json?
  order      Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([layoutId])
  @@index([moduleId])
}

// ============================================================
// Launch Day Dashboard
// ============================================================

model LaunchTelemetry {
  id           String     @id @default(cuid())
  eventId      String
  event        SpaceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timestamp    DateTime   @default(now())
  missionTime  Float // T+ seconds
  altitude     Float? // km
  velocity     Float? // km/s
  downrange    Float? // km
  acceleration Float? // g
  phase        String? // Current mission phase
  latitude     Float?
  longitude    Float?
  throttle     Float? // 0-100%
  isSimulated  Boolean    @default(true)

  @@index([eventId])
  @@index([timestamp])
}

model LaunchChatMessage {
  id        String     @id @default(cuid())
  eventId   String
  event     SpaceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  userName  String     @default("Anonymous")
  message   String
  type      String     @default("chat") // "chat", "system", "milestone"
  createdAt DateTime   @default(now())

  @@index([eventId])
  @@index([createdAt])
}

// ============================================================
// Launch Engagement (Polls & Reactions)
// ============================================================

model LaunchPoll {
  id        String     @id @default(cuid())
  eventId   String
  event     SpaceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  question  String
  options   Json // Array of option strings
  votes     Json       @default("{}") // { optionIndex: count }
  isActive  Boolean    @default(true)
  closedAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  pollVotes LaunchPollVote[]

  @@index([eventId])
  @@index([isActive])
}

model LaunchPollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      LaunchPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  option    Int // Index of chosen option
  createdAt DateTime   @default(now())

  @@unique([pollId, userId])
  @@index([pollId])
}

model LaunchReaction {
  id        String     @id @default(cuid())
  eventId   String
  event     SpaceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  emoji     String // "rocket", "fire", "star", "heart", "100"
  phase     String? // Mission phase when reaction was sent
  createdAt DateTime   @default(now())

  @@index([eventId, createdAt])
  @@index([eventId, emoji])
}

// ============================================================
// Marketplace System
// ============================================================

model ServiceListing {
  id              String         @id @default(cuid())
  companyId       String
  company         CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug            String         @unique
  name            String
  description     String         @db.Text
  category        String // launch, satellite, in_space, ground, manufacturing, engineering, environment, rnd, human, power
  subcategory     String?
  pricingType     String // fixed, hourly, per_unit, subscription, rfq_only
  priceMin        Float?
  priceMax        Float?
  priceUnit       String? // km², hour, kg, month, unit
  pricingNotes    String?        @db.Text
  specifications  Json? // Flexible specs per category
  certifications  String[] // ITAR, ISO 9001, AS9100, etc.
  pastPerformance String?        @db.Text
  leadTime        String? // "2-4 weeks", "3 months", etc.
  capacity        String? // "10 launches/year", etc.
  coverageArea    String? // "Global", "LEO", "North America"
  isEditorial     Boolean        @default(false) // Editorial listing (not created by provider)
  sourceService   String? // Source of editorial listing (e.g. 'orbital-services')
  status          String         @default("active") // active, pending, paused, archived
  featured        Boolean        @default(false)
  viewCount       Int            @default(0)
  inquiryCount    Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  matches RFQProviderMatch[]

  @@index([companyId])
  @@index([category])
  @@index([subcategory])
  @@index([status])
  @@index([pricingType])
  @@index([featured])
  @@index([isEditorial])
  @@index([category, status])
}

model RFQ {
  id                 String    @id @default(cuid())
  slug               String    @unique
  buyerUserId        String
  buyer              User      @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  title              String
  description        String    @db.Text
  category           String
  subcategory        String?
  requirements       Json? // Structured requirements per category
  budgetMin          Float?
  budgetMax          Float?
  budgetCurrency     String    @default("USD")
  deadline           DateTime? // Response deadline
  deliveryDate       DateTime? // When service is needed
  complianceReqs     String[] // ITAR, AS9100, etc.
  isPublic           Boolean   @default(true)
  status             String    @default("open") // open, evaluating, awarded, cancelled, closed
  awardedToCompanyId String? // CompanyProfile ID of winner
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  proposals      Proposal[]
  matches        RFQProviderMatch[]
  clarifications RFQClarification[]

  @@index([buyerUserId])
  @@index([category])
  @@index([status])
  @@index([isPublic])
  @@index([deadline])
  @@index([status, isPublic])
  @@index([category, status])
  @@index([createdAt])
}

model Proposal {
  id            String   @id @default(cuid())
  rfqId         String
  rfq           RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  companyId     String // CompanyProfile ID of proposer
  price         Float?
  pricingDetail String?  @db.Text
  timeline      String?
  approach      String?  @db.Text
  attachments   Json? // Array of { name, url, type }
  status        String   @default("submitted") // submitted, shortlisted, awarded, rejected, withdrawn
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([rfqId, companyId])
  @@index([rfqId])
  @@index([companyId])
  @@index([status])
  @@index([submittedAt])
  @@index([status, submittedAt])
}

model RFQProviderMatch {
  id           String          @id @default(cuid())
  rfqId        String
  rfq          RFQ             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  listingId    String?
  listing      ServiceListing? @relation(fields: [listingId], references: [id])
  companyId    String // CompanyProfile ID
  matchScore   Float // 0-100 weighted score
  matchReasons Json? // { category: 30, price: 20, certs: 20, ... }
  notified     Boolean         @default(false)
  respondedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@unique([rfqId, companyId])
  @@index([rfqId])
  @@index([companyId])
  @@index([matchScore])
}

model ProviderReview {
  id                  String         @id @default(cuid())
  companyId           String
  company             CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewerUserId      String
  rfqId               String? // Link to original RFQ if applicable
  overallRating       Int // 1-5 stars
  qualityRating       Int? // 1-5
  timelineRating      Int? // 1-5
  commRating          Int? // 1-5 Communication
  valueRating         Int? // 1-5
  title               String?
  content             String?        @db.Text
  isVerified          Boolean        @default(false) // Verified transaction
  status              String         @default("published") // published, hidden, flagged
  providerResponse    String?        @db.Text
  providerRespondedAt DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([companyId, reviewerUserId])
  @@index([companyId])
  @@index([reviewerUserId])
  @@index([overallRating])
  @@index([status])
}

model TeamingOpportunity {
  id                     String         @id @default(cuid())
  companyId              String
  company                CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractReference      String? // GovernmentContract or ProcurementOpportunity ID/title
  contractTitle          String
  contractAgency         String? // NASA, Space Force, etc.
  seekingRole            String // prime, subcontractor, teammate
  capabilitiesNeeded     String[] // What they need from partners
  capabilitiesOffered    String[] // What they bring to the team
  setAsideQualifications String[] // 8(a), HUBZone, WOSB, SDVOSB, etc.
  description            String?        @db.Text
  contactEmail           String
  status                 String         @default("open") // open, closed, teamed
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([companyId])
  @@index([contractReference])
  @@index([status])
  @@index([seekingRole])
}

model PartnershipRequest {
  id                String         @id @default(cuid())
  senderCompanyId   String
  senderCompany     CompanyProfile @relation("PartnerRequestSender", fields: [senderCompanyId], references: [id], onDelete: Cascade)
  receiverCompanyId String
  receiverCompany   CompanyProfile @relation("PartnerRequestReceiver", fields: [receiverCompanyId], references: [id], onDelete: Cascade)
  type              String // joint_venture, strategic_alliance, supply_agreement, licensing, research, teaming
  message           String?        @db.Text
  status            String         @default("pending") // pending, accepted, rejected, withdrawn
  respondedAt       DateTime?
  responseMessage   String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([senderCompanyId, receiverCompanyId])
  @@index([senderCompanyId])
  @@index([receiverCompanyId])
  @@index([status])
}

model InterestExpression {
  id            String   @id @default(cuid())
  opportunityId String // BusinessOpportunity ID
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String? // CompanyProfile ID if they have one
  contactEmail  String
  message       String?  @db.Text
  status        String   @default("expressed") // expressed, contacted, converted
  createdAt     DateTime @default(now())

  @@unique([opportunityId, userId])
  @@index([opportunityId])
  @@index([userId])
  @@index([status])
}

model RFQClarification {
  id         String    @id @default(cuid())
  rfqId      String
  rfq        RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  authorId   String
  authorRole String // 'buyer' or 'provider'
  companyId  String? // Provider's company ID if provider
  question   String    @db.Text
  answer     String?   @db.Text
  isPublic   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  answeredAt DateTime?

  @@index([rfqId])
  @@index([authorId])
}

// ─── Watchlists & Saved Searches ────────────────────────────────────────────

model CompanyWatchlistItem {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  priority         String         @default("medium") // high, medium, low
  notifyNews       Boolean        @default(true)
  notifyContracts  Boolean        @default(true)
  notifyListings   Boolean        @default(false)
  notes            String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, companyProfileId])
  @@index([userId])
  @@index([companyProfileId])
}

model SavedSearch {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  searchType   String // company_directory, marketplace_listings, marketplace_rfqs
  filters      Json // Type-specific filter object
  query        String? // Text search query
  alertEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([searchType])
}

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  platform  String // 'ios' or 'android'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Investor {
  id              String   @id @default(cuid())
  name            String   @unique
  type            String // "vc", "pe", "corporate", "angel", "government", "family_office", "accelerator"
  description     String?  @db.Text
  website         String?
  logoUrl         String?
  headquarters    String?
  foundedYear     Int?
  aum             Float? // Assets under management in USD
  fundSize        Float? // Current fund size
  investmentStage String[] // ["pre_seed", "seed", "series_a", "series_b", "growth", "late_stage"]
  sectorFocus     String[] // ["launch", "satellite", "earth_observation", "defense", "in_space", "ground_segment"]
  portfolioCount  Int? // Known space portfolio companies
  notableDeals    String[] // Notable space investments as text descriptions
  linkedinUrl     String?
  status          String   @default("active") // "active", "inactive", "new_fund"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([name])
  @@index([status])
}

// ── Deal Room (Space Industry Deal Room) ──

model DealRoom {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  companySlug     String? // Link to CompanyProfile
  status          String   @default("active") // "active", "archived", "closed"
  createdBy       String // User ID or email who created the room
  createdByUserId String? // User ID of creator (nullable for backward compat)
  accessCode      String?  @unique // Optional invite code
  ndaRequired     Boolean  @default(false)
  ndaText         String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members    DealRoomMember[]
  documents  DealRoomDocument[]
  activities DealRoomActivity[]

  @@index([createdBy])
  @@index([createdByUserId])
  @@index([status])
  @@index([companySlug])
}

model DealRoomMember {
  id            String    @id @default(cuid())
  dealRoomId    String
  dealRoom      DealRoom  @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  userId        String? // Null for invited-but-not-joined
  email         String
  role          String    @default("viewer") // "owner", "admin", "viewer"
  ndaAcceptedAt DateTime?
  invitedAt     DateTime  @default(now())
  joinedAt      DateTime?
  lastAccessAt  DateTime?

  @@unique([dealRoomId, email])
  @@index([dealRoomId])
  @@index([userId])
  @@index([email])
}

model DealRoomDocument {
  id          String   @id @default(cuid())
  dealRoomId  String
  dealRoom    DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  name        String
  category    String   @default("general") // "pitch_deck", "financials", "technical", "legal", "team", "general"
  fileType    String // "pdf", "pptx", "xlsx", "docx", "png", "jpg"
  fileSize    Int // Bytes
  uploadedBy  String // User ID or email
  description String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dealRoomId])
  @@index([category])
}

model DealRoomActivity {
  id         String   @id @default(cuid())
  dealRoomId String
  dealRoom   DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  userId     String?
  userEmail  String?
  action     String // "viewed_document", "uploaded_document", "joined_room", "accepted_nda", "invited_member", "downloaded_document", "created_room"
  details    String? // Document name, member email, etc.
  createdAt  DateTime @default(now())

  @@index([dealRoomId])
  @@index([createdAt])
}

// ============================================================
// Weekly Intelligence Brief
// ============================================================

model WeeklyIntelligenceBrief {
  id             String    @id @default(cuid())
  weekStart      DateTime
  weekEnd        DateTime
  content        Json
  htmlContent    String?   @db.Text
  sentAt         DateTime?
  recipientCount Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// Community: Professional Directory & Follow System
// ============================================================

model ProfessionalProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline    String? // "VP Engineering at SpaceX"
  bio         String?  @db.Text
  expertise   String[] // ["propulsion", "launch-ops", "mission-planning"]
  location    String?
  linkedinUrl String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublic])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model CompanyFollow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

// ============================================================
// Community: Direct Messaging
// ============================================================

model Conversation {
  id            String                    @id @default(cuid())
  participants  ConversationParticipant[]
  messages      DirectMessage[]
  lastMessageAt DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ============================================================
// Community: Industry Forums
// ============================================================

model ForumCategory {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  icon        String?
  threads     ForumThread[]
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  @@index([sortOrder])
}

model ForumThread {
  id             String               @id @default(cuid())
  categoryId     String
  category       ForumCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId       String
  author         User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  companyId      String?
  company        CompanyProfile?      @relation("CompanyForumThreads", fields: [companyId], references: [id], onDelete: SetNull)
  title          String
  content        String               @db.Text
  posts          ForumPost[]
  isPinned       Boolean              @default(false)
  isLocked       Boolean              @default(false)
  viewCount      Int                  @default(0)
  tags           String[]
  acceptedPostId String?
  upvoteCount    Int                  @default(0)
  downvoteCount  Int                  @default(0)
  votes          ThreadVote[]
  subscriptions  ThreadSubscription[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([categoryId, createdAt])
  @@index([authorId])
  @@index([isPinned, createdAt])
}

model ForumPost {
  id            String          @id @default(cuid())
  threadId      String
  thread        ForumThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId      String
  author        User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  companyId     String?
  company       CompanyProfile? @relation("CompanyForumPosts", fields: [companyId], references: [id], onDelete: SetNull)
  content       String          @db.Text
  upvoteCount   Int             @default(0)
  downvoteCount Int             @default(0)
  isAccepted    Boolean         @default(false)
  votes         PostVote[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId])
}

// ============================================================
// Community: Content Reporting & Moderation
// ============================================================

model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("reportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  contentType String // 'thread', 'post', 'message', 'profile'
  contentId   String
  reason      String // 'spam', 'harassment', 'itar_violation', 'copyright', 'inappropriate', 'hate_speech', 'other'
  description String?  @db.Text
  status      String   @default("pending") // 'pending', 'reviewed', 'actioned', 'dismissed'
  reviewedBy  String?
  reviewNote  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contentType, contentId])
  @@index([status])
  @@index([reporterId])
  @@index([createdAt])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blocksGiven", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model ModerationAction {
  id           String   @id @default(cuid())
  moderatorId  String
  targetUserId String
  action       String // 'warn', 'mute', 'unmute', 'ban', 'unban', 'delete_content'
  reason       String?  @db.Text
  contentType  String?
  contentId    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([targetUserId])
  @@index([moderatorId])
  @@index([createdAt])
}

// ============================================================
// Community: Voting
// ============================================================

model PostVote {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int // 1 (upvote) or -1 (downvote)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model ThreadVote {
  id        String      @id @default(cuid())
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int // 1 (upvote) or -1 (downvote)
  createdAt DateTime    @default(now())

  @@unique([threadId, userId])
  @@index([threadId])
  @@index([userId])
}

// ============================================================
// Community: Notifications
// ============================================================

model Notification {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               String // 'reply', 'mention', 'follow', 'vote', 'accepted_answer', 'moderation'
  title              String
  message            String
  relatedUserId      String?
  relatedContentType String?
  relatedContentId   String?
  linkUrl            String?
  read               Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============================================================
// Community: Thread Subscriptions
// ============================================================

model ThreadSubscription {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, threadId])
  @@index([threadId])
}

// ============================================================
// Admin: Audit Logging
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     String // 'grant_admin', 'revoke_admin', 'update_role', 'seed_data', 'refresh_data', 'ban_user', 'mute_user', etc.
  resource   String // 'user', 'content', 'data', 'system'
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailDigest        Boolean  @default(true)
  emailAlerts        Boolean  @default(true)
  pushEnabled        Boolean  @default(true)
  forumReplies       Boolean  @default(true)
  directMessages     Boolean  @default(true)
  marketplaceUpdates Boolean  @default(true)
  watchlistAlerts    Boolean  @default(true)
  newsDigest         Boolean  @default(true)
  digestFrequency    String   @default("daily") // "daily", "weekly", "none"
  // Smart batching & quiet hours (v1.2.0)
  alertDigestMode    String   @default("instant") // "instant", "hourly", "daily", "weekly"
  quietHoursStart    Int? // Hour 0-23, null = disabled
  quietHoursEnd      Int? // Hour 0-23, null = disabled
  quietHoursTimezone String   @default("UTC")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Blog Analytics
// ---------------------------------------------------------------------------

model BlogPostView {
  id          String   @id @default(cuid())
  slug        String   @unique
  viewCount   Int      @default(0)
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([viewCount])
}

// ---------------------------------------------------------------------------
// Community Badges
// ---------------------------------------------------------------------------

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeType String // first_post, helpful_10, expert, top_contributor, space_authority
  awardedAt DateTime @default(now())

  @@unique([userId, badgeType])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Video Content
// ---------------------------------------------------------------------------

model VideoContent {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String   @db.Text
  youtubeId    String?
  thumbnailUrl String?
  duration     Int? // seconds
  category     String // tutorial, launch-replay, interview, explainer
  tags         String[]
  featured     Boolean  @default(false)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([category])
  @@index([publishedAt])
}

// ---------------------------------------------------------------------------
// Space Tycoon: Multiplayer Systems
// ---------------------------------------------------------------------------

// Server-validated "first to" milestones — only one player can claim each
model GlobalMilestone {
  id          String      @id @default(cuid())
  milestoneId String      @unique // matches milestones.ts ID (first_orbit, first_moon, etc.)
  claimedById String
  claimedBy   GameProfile @relation(fields: [claimedById], references: [id], onDelete: Cascade)
  companyName String
  reward      Float
  claimedAt   DateTime    @default(now())

  @@index([milestoneId])
}

// Player-to-player resource bounties (contracts marketplace)
model ResourceBounty {
  id           String       @id @default(cuid())
  posterId     String
  poster       GameProfile  @relation("postedBounties", fields: [posterId], references: [id], onDelete: Cascade)
  resourceSlug String // iron, titanium, etc.
  quantity     Int
  pricePerUnit Float // what poster will pay per unit
  totalBudget  Float // quantity * pricePerUnit (escrowed)
  filledQty    Int          @default(0)
  status       String       @default("open") // open, partial, filled, cancelled
  fillerId     String?
  filler       GameProfile? @relation("filledBounties", fields: [fillerId], references: [id])
  filledAt     DateTime?
  createdAt    DateTime     @default(now())
  expiresAt    DateTime // auto-expire after 24h

  @@index([status])
  @@index([resourceSlug])
  @@index([createdAt])
}

// Player alliances for shared bonuses
model Alliance {
  id            String           @id @default(cuid())
  name          String           @unique
  tag           String           @unique // 3-5 char tag like [SOL], [MARS]
  description   String?
  leaderId      String
  memberCount   Int              @default(1)
  totalNetWorth Float            @default(0)
  bonusRevenue  Float            @default(0.05) // +5% revenue per alliance member (capped)
  members       AllianceMember[]
  createdAt     DateTime         @default(now())

  // ── Mechanic 5: Alliance Cooperative Competition ──
  level                  Int   @default(1)
  xp                     Int   @default(0)
  tier                   Int   @default(1) // 1-5 (Frontier Startup → Galactic Dominion)
  powerScore             Float @default(0) // Composite Alliance Power Score
  totalEventsWon         Int   @default(0)
  totalProjectsCompleted Int   @default(0)
  treasury               Float @default(0) // Shared money pool
  announcements          Json  @default("[]") // Array of { text, authorId, createdAt }
  settings               Json  @default("{}") // { minActivityDays, autoKickDays, maxOfficers }

  // Relations for competitive mechanics
  allianceEventScores       AllianceEventScore[]
  allianceProjects          AllianceProject[]
  allianceDailyTasks        AllianceDailyTask[]
  megaProjectAllianceScores MegaProjectAllianceScore[]
  zoneInfluences            ZoneInfluence[]

  // ── Deep Alliance System ──
  motd             String? // Message of the day (leader sets)
  bannerColor      String  @default("#6366f1") // Alliance banner/accent color
  iconId           String  @default("rocket_1") // Alliance icon from preset list
  isRecruiting     Boolean @default(true)
  requiredNetWorth Float   @default(0) // Min net worth to join
  warWins          Int     @default(0)
  warLosses        Int     @default(0)

  allianceResearch  AllianceResearch[]
  allianceLogs      AllianceLog[]
  alliancePerks     AlliancePerk[]
  diplomacySent     AllianceDiplomacy[] @relation("diplomacySender")
  diplomacyReceived AllianceDiplomacy[] @relation("diplomacyReceiver")

  @@index([totalNetWorth])
  @@index([powerScore])
  @@index([tier])
  @@index([isRecruiting])
}

model AllianceMember {
  id         String      @id @default(cuid())
  allianceId String
  alliance   Alliance    @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  profileId  String      @unique
  profile    GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role       String      @default("member") // leader, officer, veteran, member, recruit
  joinedAt   DateTime    @default(now())

  // ── Mechanic 5: Alliance Cooperative Competition ──
  roleTag        String? // "miner", "researcher", "builder", "trader" (advisory)
  status         String   @default("active") // active, idle, inactive, dormant
  lastActiveAt   DateTime @default(now())
  activityStreak Int      @default(0)
  totalXPEarned  Int      @default(0)
  statusMessage  String? // 50-char status line

  @@index([allianceId])
}

// Global activity feed — visible to all players
model PlayerActivity {
  id          String      @id @default(cuid())
  profileId   String
  profile     GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyName String
  type        String // milestone_claimed, big_trade, alliance_created, bounty_posted, prestige
  title       String
  description String?
  metadata    Json? // extra data (resource, quantity, price, etc.)
  createdAt   DateTime    @default(now())

  @@index([type])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Executive Moves (Leadership tracking)
// ---------------------------------------------------------------------------

model ExecutiveMove {
  id          String   @id @default(cuid())
  personName  String
  fromCompany String?
  fromTitle   String?
  toCompany   String?
  toTitle     String?
  moveType    String // hired, departed, promoted, appointed, board_joined
  date        DateTime
  source      String?
  sourceUrl   String?
  summary     String?  @db.Text
  companySlug String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([personName])
  @@index([companySlug])
  @@index([date])
  @@index([moveType])
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPETITIVE MULTIPLAYER MODELS
// ═══════════════════════════════════════════════════════════════════════════════

// ── Mechanic 1: Tiered/Bracketed Leaderboards ──────────────────────────────

model LeagueSeason {
  id           String   @id @default(cuid())
  seasonNumber Int      @unique
  weekNumber   Int // week within the season (1-12)
  metricSlug   String // "net_worth_growth", "trade_volume", etc.
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())

  brackets LeagueBracket[]

  @@index([isActive])
  @@index([startsAt])
}

model LeagueBracket {
  id           String       @id @default(cuid())
  seasonId     String
  season       LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  league       Int // 1-8 (Suborbital through Galactic)
  bracketIndex Int // multiple brackets per league
  createdAt    DateTime     @default(now())

  entries LeagueBracketEntry[]

  @@unique([seasonId, league, bracketIndex])
  @@index([seasonId])
  @@index([league])
}

model LeagueBracketEntry {
  id        String        @id @default(cuid())
  bracketId String
  bracket   LeagueBracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  profileId String
  profile   GameProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  startValue   Float // metric value at week start (snapshot)
  currentValue Float @default(0) // latest metric value
  score        Float @default(0) // computed: delta or % change
  rank         Int   @default(0)

  promoted Boolean @default(false)
  demoted  Boolean @default(false)
  shielded Boolean @default(false) // promotion shield active

  rewardClaimed Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([bracketId, profileId])
  @@index([bracketId, score])
  @@index([profileId])
}

model PlayerLeagueProfile {
  id        String      @id @default(cuid())
  profileId String      @unique
  profile   GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  currentLeague    Int     @default(1) // 1-8
  peakLeague       Int     @default(1)
  promotionShield  Boolean @default(false)
  consecutiveLow   Int     @default(0)
  seasonPoints     Int     @default(0)
  totalWeeksPlayed Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([currentLeague])
}

// ── Mechanic 2: Ghost/Shadow Rivals ────────────────────────────────────────

model RivalAssignment {
  id       String      @id @default(cuid())
  playerId String
  player   GameProfile @relation("rivalPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  rivalId  String
  rival    GameProfile @relation("rivalTarget", fields: [rivalId], references: [id], onDelete: Cascade)

  rivalryScore Float   @default(50) // 0-100 tug-of-war
  weekId       Int // getCurrentWeekId() value
  isActive     Boolean @default(true)

  snapshots RivalSnapshot[]
  events    RivalEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, rivalId, weekId])
  @@index([playerId, isActive])
  @@index([rivalId])
  @@index([weekId])
}

model RivalSnapshot {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   RivalAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  playerNetWorth  Float
  rivalNetWorth   Float
  playerBuildings Int
  rivalBuildings  Int
  playerResearch  Int
  rivalResearch   Int
  playerServices  Int
  rivalServices   Int
  scoreDelta      Float @default(0) // Change to rivalry score

  snapshotAt DateTime @default(now())

  @@index([assignmentId])
  @@index([snapshotAt])
}

model RivalEvent {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   RivalAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  type        String // "overtook", "was_overtaken", "new_rival", "rival_milestone", etc.
  title       String
  description String?
  metadata    Json?
  notified    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([assignmentId])
  @@index([type])
  @@index([createdAt])
}

// ── Mechanic 3: Contract Bidding System ────────────────────────────────────

model BiddingContract {
  id           String @id @default(cuid())
  contractType String // satellite_deployment, resource_delivery, station_construction, etc.
  tier         Int // 1-4
  title        String
  description  String

  requirements  Json // { type-specific requirements }
  baseReward    Float
  minBid        Float
  maxBid        Float
  collateralPct Float @default(0.10) // 5-15% by tier

  bidCount   Int          @default(0)
  winnerId   String?
  winner     GameProfile? @relation("contractWinner", fields: [winnerId], references: [id])
  winningBid Float?

  status           String    @default("open") // open, bidding_closed, awarded, in_progress, completed, failed
  biddingEndsAt    DateTime
  deliveryDeadline DateTime?
  completedAt      DateTime?

  bids ContractBid[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([tier])
  @@index([contractType])
  @@index([biddingEndsAt])
}

model ContractBid {
  id         String          @id @default(cuid())
  contractId String
  contract   BiddingContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  profileId  String
  profile    GameProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  bidAmount        Float
  deliveryPromise  Int? // Promised delivery in hours
  collateralLocked Float  @default(0)
  compositeScore   Float? // Computed: 70% price + 15% reputation + 15% speed

  status    String   @default("pending") // pending, won, lost, withdrawn
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, profileId])
  @@index([contractId])
  @@index([profileId])
  @@index([status])
}

// ── Mechanic 4: Seasonal Event Competitions ────────────────────────────────

model SeasonalEvent {
  id           String @id @default(cuid())
  seasonType   String // asteroid_rush, mars_colony_race, solar_storm_crisis, helium3_gold_rush, fleet_command
  seasonNumber Int
  title        String
  description  String

  startsAt DateTime
  endsAt   DateTime
  status   String   @default("upcoming") // upcoming, active, completed

  // Season Pass config
  passRewards   Json @default("[]") // Array of tier reward definitions
  challengePool Json @default("[]") // Pool of daily/weekly challenge definitions

  metadata Json? // Season-specific config

  participations   SeasonParticipation[]
  seasonChallenges SeasonChallenge[]

  createdAt DateTime @default(now())

  @@unique([seasonType, seasonNumber])
  @@index([status])
  @@index([startsAt])
}

model SeasonParticipation {
  id        String        @id @default(cuid())
  eventId   String
  event     SeasonalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profileId String
  profile   GameProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  eventState   Json @default("{}") // Separate EventGameState
  seasonPoints Int  @default(0) // SP earned this season
  currentTier  Int  @default(0) // Season pass tier reached (0-50)
  bracket      Int  @default(1) // Player bracket (1-5 by net worth)

  totalScore Float @default(0) // Final ranking score
  rank       Int?

  rewardsClaimed Json @default("[]") // Tiers already claimed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, profileId])
  @@index([eventId, totalScore])
  @@index([profileId])
}

model SeasonChallenge {
  id      String        @id @default(cuid())
  eventId String
  event   SeasonalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  challengeType String // "daily", "weekly", "season"
  title         String
  description   String
  metric        String // What to measure
  target        Float // Target value
  spReward      Int // Season Points awarded
  activeDate    DateTime? // For daily challenges
  activeWeek    Int? // For weekly challenges

  createdAt DateTime @default(now())

  @@index([eventId, challengeType])
  @@index([activeDate])
}

// ── Mechanic 5: Alliance Cooperative Competition ───────────────────────────

model AllianceEvent {
  id            String   @id @default(cuid())
  eventType     String // "asteroid_rush", "launch_blitz", "research_sprint", etc.
  eventCategory String // "sprint", "challenge", "mega_event"
  bracketId     String // Groups alliances competing against each other
  startsAt      DateTime
  endsAt        DateTime
  status        String   @default("upcoming") // upcoming, active, completed
  metadata      Json? // Event-specific config

  scores        AllianceEventScore[]
  contributions AllianceEventContribution[]

  createdAt DateTime @default(now())

  @@index([status])
  @@index([bracketId])
  @@index([startsAt])
}

model AllianceEventScore {
  id                String        @id @default(cuid())
  eventId           String
  event             AllianceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  allianceId        String
  alliance          Alliance      @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  totalScore        Float         @default(0)
  perCapitaScore    Float         @default(0)
  activeMemberCount Int           @default(0)
  bracketRank       Int?
  rewardClaimed     Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([eventId, allianceId])
  @@index([eventId])
  @@index([allianceId])
}

model AllianceEventContribution {
  id         String        @id @default(cuid())
  eventId    String
  event      AllianceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  allianceId String
  profileId  String
  profile    GameProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  score      Float         @default(0)
  details    Json? // Breakdown: { "iron_mined": 500, "titanium_mined": 200 }
  updatedAt  DateTime      @updatedAt

  @@unique([eventId, profileId])
  @@index([eventId, allianceId])
  @@index([profileId])
}

model AllianceProject {
  id              String    @id @default(cuid())
  allianceId      String
  alliance        Alliance  @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  projectType     String // "orbital_mega_station", "space_elevator", etc.
  name            String
  status          String    @default("funding") // funding, building, completed, decommissioned
  moneyCost       Float
  moneyFunded     Float     @default(0)
  resourceCosts   Json // { "titanium": 10000, "carbon_fiber": 20000 }
  resourceFunded  Json      @default("{}")
  fundingDeadline DateTime?
  buildStartAt    DateTime?
  buildEndAt      DateTime?
  completedAt     DateTime?
  bonuses         Json // The bonuses this project grants when complete

  contributions AllianceProjectContribution[]

  createdAt DateTime @default(now())

  @@index([allianceId])
  @@index([status])
}

model AllianceProjectContribution {
  id                   String          @id @default(cuid())
  projectId            String
  project              AllianceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profileId            String
  moneyContributed     Float           @default(0)
  resourcesContributed Json            @default("{}")
  contributionShare    Float           @default(0)
  updatedAt            DateTime        @updatedAt

  @@unique([projectId, profileId])
  @@index([projectId])
  @@index([profileId])
}

model AllianceDailyTask {
  id         String   @id @default(cuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  date       DateTime // Date (UTC day)
  tasks      Json // Array of 3 task definitions
  createdAt  DateTime @default(now())

  completions AllianceDailyTaskCompletion[]

  @@unique([allianceId, date])
}

model AllianceDailyTaskCompletion {
  id          String            @id @default(cuid())
  dailyTaskId String
  dailyTask   AllianceDailyTask @relation(fields: [dailyTaskId], references: [id], onDelete: Cascade)
  profileId   String
  taskIndex   Int // 0, 1, or 2
  completedAt DateTime          @default(now())

  @@unique([dailyTaskId, profileId, taskIndex])
  @@index([profileId])
}

// ── Mechanic 6: Player-Driven Marketplace Enhancement ──────────────────────

model MarketLimitOrder {
  id           String    @id @default(cuid())
  profileId    String
  resourceSlug String
  side         String // "buy" | "sell"
  quantity     Int
  filledQty    Int       @default(0)
  pricePerUnit Int // Integer cents to avoid float issues
  escrowAmount Int       @default(0) // Money or resources locked
  status       String    @default("open") // open, partial, filled, cancelled, expired
  expiresAt    DateTime?

  fills        MarketFill[] @relation("orderFills")
  counterFills MarketFill[] @relation("counterFills")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resourceSlug, side, status])
  @@index([profileId])
  @@index([status])
  @@index([createdAt])
}

model MarketFill {
  id             String           @id @default(cuid())
  orderId        String
  order          MarketLimitOrder @relation("orderFills", fields: [orderId], references: [id], onDelete: Cascade)
  counterOrderId String
  counterOrder   MarketLimitOrder @relation("counterFills", fields: [counterOrderId], references: [id], onDelete: Cascade)

  quantity        Int
  pricePerUnit    Int
  totalValue      Int
  fee             Int    @default(0) // 2% transaction fee
  buyerProfileId  String
  sellerProfileId String

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([counterOrderId])
  @@index([createdAt])
}

model MarketPriceCandle {
  id           String   @id @default(cuid())
  resourceSlug String
  timeframe    String // "1h", "4h", "1d", "1w"
  openTime     DateTime
  open         Int
  high         Int
  low          Int
  close        Int
  volume       Int      @default(0)
  tradeCount   Int      @default(0)

  @@unique([resourceSlug, timeframe, openTime])
  @@index([resourceSlug, timeframe])
  @@index([openTime])
}

model MarketAlert {
  id           String    @id @default(cuid())
  profileId    String
  resourceSlug String
  direction    String // "above" | "below"
  targetPrice  Int
  triggered    Boolean   @default(false)
  triggeredAt  DateTime?

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([resourceSlug, triggered])
}

model MarketAuditLog {
  id           String   @id @default(cuid())
  eventType    String // "self_trade_blocked", "price_spike", "volume_anomaly", etc.
  profileId    String?
  resourceSlug String?
  details      Json
  severity     String   @default("info") // info, warning, critical
  createdAt    DateTime @default(now())

  @@index([eventType])
  @@index([profileId])
  @@index([createdAt])
}

// ── Mechanic 7: Territory/Zone Influence ───────────────────────────────────

model Zone {
  id           String  @id @default(cuid())
  slug         String  @unique // "leo", "geo", "lunar", "mars", etc.
  name         String
  parentZone   String? // null for major zones, parent slug for sub-zones
  tier         Int     @default(1)
  governorId   String? // Profile ID of current governor
  governorName String?
  customName   String? // Governor-assigned zone name

  influences ZoneInfluence[]
  challenges GovernanceChallenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentZone])
  @@index([governorId])
}

model ZoneInfluence {
  id         String       @id @default(cuid())
  zoneId     String
  zone       Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  profileId  String?
  profile    GameProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  allianceId String?
  alliance   Alliance?    @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  influencePoints Float    @default(0)
  sharePercent    Float    @default(0) // Cached % share of zone
  lastDecayAt     DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([zoneId, profileId])
  @@index([zoneId])
  @@index([profileId])
  @@index([allianceId])
}

model GovernanceChallenge {
  id              String      @id @default(cuid())
  zoneId          String
  zone            Zone        @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  challengerId    String
  challenger      GameProfile @relation(fields: [challengerId], references: [id], onDelete: Cascade)
  currentGovernor String // Profile ID
  challengerIP    Float // IP at challenge start
  governorIP      Float // IP at challenge start
  status          String      @default("active") // active, challenger_won, governor_held, expired
  endsAt          DateTime // 72-hour window

  createdAt DateTime @default(now())

  @@index([zoneId, status])
  @@index([challengerId])
  @@index([endsAt])
}

// ── Mechanic 8: Prestige Speed Runs ───────────────────────────────────────

model SpeedRunChallenge {
  id              String   @id @default(cuid())
  weekId          Int      @unique // Deterministic week identifier
  milestoneId     String // Which milestone to race for
  milestoneName   String
  milestoneTarget String // Human-readable target
  bracket         String? // null = all brackets, or "rookie", "veteran", "elite", "grandmaster"
  startsAt        DateTime
  endsAt          DateTime
  status          String   @default("upcoming") // upcoming, active, completed

  attempts SpeedRunAttempt[]

  createdAt DateTime @default(now())

  @@index([status])
  @@index([weekId])
}

model SpeedRunAttempt {
  id          String            @id @default(cuid())
  challengeId String
  challenge   SpeedRunChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  profileId   String
  profile     GameProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)

  prestigeLevel   Int // Player's prestige level at attempt start
  bracket         String // rookie, veteran, elite, grandmaster
  startedAtMs     Float // Unix timestamp when prestige reset occurred
  completedAtMs   Float? // Unix timestamp when milestone was reached
  durationSeconds Float? // Computed time to completion
  rank            Int?

  isVerified     Boolean @default(false) // Server-validated
  suspicionScore Float   @default(0) // Anti-cheat score

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([challengeId, profileId])
  @@index([challengeId, bracket])
  @@index([profileId])
  @@index([durationSeconds])
}

// ── Mechanic 9: Economic Espionage ────────────────────────────────────────

model EspionageProfile {
  id        String      @id @default(cuid())
  profileId String      @unique
  profile   GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  securityLevel   Int      @default(1) // 1-10
  actionsToday    Int      @default(0)
  lastActionReset DateTime @default(now())

  // Counter-espionage
  blacklist       String[]  @default([]) // Profile IDs blocked from targeting
  heightenedAlert Boolean   @default(false)
  alertExpiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EspionageMission {
  id         String      @id @default(cuid())
  attackerId String
  attacker   GameProfile @relation("missionAttacker", fields: [attackerId], references: [id], onDelete: Cascade)
  targetId   String
  target     GameProfile @relation("missionTarget", fields: [targetId], references: [id], onDelete: Cascade)

  actionType  String // "market_spy", "tech_probe", "workforce_intel", "contract_snipe", etc.
  cost        Float // Money spent on the operation
  successRate Float // Probability at time of execution
  succeeded   Boolean
  detected    Boolean @default(false) // Was the target alerted?
  tracedBack  Boolean @default(false) // Was attacker identified?

  // Results
  intelGathered  Json? // What info was obtained
  intelExpiresAt DateTime? // Intel freshness window
  reward         Json? // What bonus was earned

  createdAt DateTime @default(now())

  @@index([attackerId])
  @@index([targetId])
  @@index([actionType])
  @@index([createdAt])
}

// ── Mechanic 10: Cooperative Mega-Projects ────────────────────────────────

model MegaProject {
  id          String @id @default(cuid())
  projectType String // "space_elevator", "generation_ship", "dyson_sphere", "interstellar_probe"
  title       String
  description String

  // Requirements per current phase
  currentPhase Int  @default(1)
  totalPhases  Int
  phaseCosts   Json // Array of { phase, moneyCost, resourceCosts }

  // Aggregate funding
  totalMoneyFunded    Float @default(0)
  totalResourceFunded Json  @default("{}")

  status         String    @default("announced") // announced, active, extended, completed, shelved
  startsAt       DateTime
  endsAt         DateTime
  completedAt    DateTime?
  extensionCount Int       @default(0)

  // Permanent bonus granted on completion
  permanentBonus Json // { type: "launch_cost_reduction", value: 0.15 }

  contributions  MegaProjectContribution[]
  allianceScores MegaProjectAllianceScore[]
  playerProgress MegaProjectPlayerProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startsAt])
}

model MegaProjectContribution {
  id        String      @id @default(cuid())
  projectId String
  project   MegaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profileId String
  profile   GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  moneyContributed     Float @default(0)
  resourcesContributed Json  @default("{}")
  totalMPP             Float @default(0) // Mega-Project Points

  updatedAt DateTime @updatedAt

  @@unique([projectId, profileId])
  @@index([projectId, totalMPP])
  @@index([profileId])
}

model MegaProjectAllianceScore {
  id         String      @id @default(cuid())
  projectId  String
  project    MegaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allianceId String
  alliance   Alliance    @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  totalMPP     Float   @default(0)
  perCapitaMPP Float   @default(0)
  rank         Int?
  namingRights Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@unique([projectId, allianceId])
  @@index([projectId, totalMPP])
  @@index([allianceId])
}

model MegaProjectPlayerProgress {
  id        String      @id @default(cuid())
  projectId String
  project   MegaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profileId String      @unique
  profile   GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  contributionTier Int  @default(0) // 0-7 tier based on total MPP
  rewardsClaimed   Json @default("[]")

  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([profileId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEEP ALLIANCE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

// Alliance shared research tree — unlockable bonuses that benefit all members
model AllianceResearch {
  id         String   @id @default(cuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  researchId String // "alliance_logistics_1", "alliance_mining_2", etc.
  name       String
  tier       Int // 1-5
  category   String // logistics, mining, commerce, military, science, infrastructure

  status       String @default("locked") // locked, researching, completed
  xpCost       Int // Alliance XP spent to unlock
  treasuryCost Float  @default(0) // Treasury money spent
  progressPct  Float  @default(0) // 0-100 during researching

  startedAt   DateTime?
  completedAt DateTime?
  startedBy   String? // Profile ID of who initiated

  // What bonus this research provides
  bonusType  String // revenue_bonus, mining_bonus, research_speed, build_speed, member_cap, project_speed, trade_bonus, xp_multiplier
  bonusValue Float // e.g., 0.03 = +3%

  createdAt DateTime @default(now())

  @@unique([allianceId, researchId])
  @@index([allianceId, status])
  @@index([category])
}

// Alliance diplomacy — relations between alliances
model AllianceDiplomacy {
  id         String   @id @default(cuid())
  senderId   String
  sender     Alliance @relation("diplomacySender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Alliance @relation("diplomacyReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  type       String // "war", "trade_agreement", "non_aggression", "alliance_pact"
  status     String @default("pending") // pending, active, rejected, expired, broken
  proposedBy String // Profile ID

  // War-specific
  warScore     Json? // { senderScore: 0, receiverScore: 0 }
  warObjective String? // "zone_control", "economic_dominance", "event_supremacy"

  // Trade agreement specifics
  tradeBonus Float? // Mutual trade fee discount

  startsAt   DateTime?
  endsAt     DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId, type])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@index([type, status])
}

// Alliance perks — temporary buffs purchased from treasury
model AlliancePerk {
  id         String   @id @default(cuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  perkId      String // "revenue_surge", "mining_frenzy", "research_rush", etc.
  name        String
  description String

  bonusType     String // revenue_bonus, mining_bonus, research_speed, build_speed, xp_multiplier
  bonusValue    Float // e.g., 0.10 = +10%
  treasuryCost  Float // How much it cost from treasury
  durationHours Int // How long it lasts

  activatedAt DateTime @default(now())
  expiresAt   DateTime
  activatedBy String // Profile ID

  @@index([allianceId])
  @@index([expiresAt])
}

// Alliance activity log — tracks all significant alliance actions
model AllianceLog {
  id         String   @id @default(cuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  type        String // member_joined, member_left, member_promoted, member_demoted,
  // project_proposed, project_funded, project_completed,
  // event_won, event_completed, research_started, research_completed,
  // perk_activated, war_declared, treaty_signed, treasury_deposit, xp_earned
  actorId     String? // Profile ID of who did it (null for system events)
  actorName   String? // Company name snapshot
  title       String
  description String?
  metadata    Json? // Extra data
  xpEarned    Int     @default(0) // XP earned from this action

  createdAt DateTime @default(now())

  @@index([allianceId, createdAt])
  @@index([type])
}

// ─── Gig/Freelance Marketplace ────────────────────────────────────────────────

model WorkerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  headline        String // e.g., "Propulsion Engineer | 10yr SpaceX"
  bio             String?  @db.Text
  skills          String[] // e.g., ["propulsion", "avionics", "systems_engineering"]
  experienceYears Int?
  hourlyRate      Int? // USD per hour, null = negotiable
  availability    String   @default("available") // available, part_time, contract_only, unavailable
  workType        String[] // ["freelance", "contract", "part_time", "consulting", "side_project"]
  linkedInUrl     String?
  portfolioUrl    String?
  location        String?
  remoteOk        Boolean  @default(true)
  clearanceLevel  String? // none, secret, top_secret
  visible         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([availability])
  @@index([visible])
}

model GigOpportunity {
  id                String          @id @default(cuid())
  employerId        String
  employer          EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  companyProfileId  String?
  companyProfile    CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  title             String
  description       String          @db.Text
  category          String // engineering, operations, business, research, legal, manufacturing
  skills            String[] // required skills
  workType          String // freelance, contract, part_time, consulting, side_project
  duration          String? // e.g., "3 months", "ongoing", "one-time"
  hoursPerWeek      Int? // estimated hours
  budgetMin         Int? // USD total or per hour
  budgetMax         Int?
  budgetType        String          @default("hourly") // hourly, fixed, monthly
  location          String?
  remoteOk          Boolean         @default(true)
  clearanceRequired Boolean         @default(false)
  isActive          Boolean         @default(true)
  applicantCount    Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([isActive])
  @@index([category])
  @@index([workType])
}

model EmployerProfile {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  companySlug String? // links to CompanyProfile if exists
  description String?          @db.Text
  website     String?
  industry    String? // e.g., "launch_services", "satellite_operations"
  size        String? // startup, small, medium, large, enterprise
  location    String?
  logoUrl     String?
  verified    Boolean          @default(false)
  gigs        GigOpportunity[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// ─── Live Blog ──────────────────────────────────────────────────────────────

model LiveBlogEntry {
  id        String   @id @default(uuid())
  title     String
  body      String
  type      String   @default("update") // update, milestone, alert, media, countdown
  source    String   @default("admin") // admin, auto, nasa
  pinned    Boolean  @default(false)
  eventTag  String? // e.g. "artemis-ii" — allows filtering by event
  createdAt DateTime @default(now())

  @@index([eventTag, createdAt])
}

// ─── Usage Analytics ────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String? // for anonymous tracking
  event     String // e.g. "module_viewed", "feature_clicked", "upgrade_clicked"
  module    String? // e.g. "bd-pipeline", "dossiers", "market-intel"
  metadata  Json? // arbitrary extra context
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([event])
  @@index([module])
  @@index([createdAt])
}

// ─── Wave 1: Speaking Opportunities ─────────────────────────────────────────

model SpeakingOpportunity {
  id             String   @id @default(cuid())
  title          String
  organization   String
  conferenceName String?
  topic          String
  description    String   @db.Text
  eventDate      DateTime
  submissionDeadline DateTime?
  location       String?
  isRemote       Boolean  @default(false)
  compensation   String? // "paid" | "travel" | "unpaid" | free text
  audienceSize   Int?
  cfpUrl         String? // Call-for-papers URL
  contactEmail   String?
  contactName    String?
  submittedById  String?
  submittedBy    User?    @relation("SubmittedSpeakingOps", fields: [submittedById], references: [id], onDelete: SetNull)
  status         String   @default("pending") // pending | approved | rejected | expired
  featured       Boolean  @default(false)
  tags           String[] // e.g. ["policy", "GNC", "launch-ops"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([eventDate])
  @@index([submissionDeadline])
  @@index([status])
  @@index([organization])
}

// ─── Wave 1: Pitch Decks & Data Room ────────────────────────────────────────

model PitchDeck {
  id             String        @id @default(cuid())
  companyId      String
  company        CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title          String
  description    String?       @db.Text
  fileUrl        String
  fileSize       Int?
  visibility     String        @default("logged_in") // public | logged_in | invite_only
  roundType      String? // pre-seed | seed | series_a | series_b | growth
  amountRaising  Float?
  currency       String?       @default("USD")
  uploadedByUserId String?
  views          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  accessLogs     PitchDeckView[]

  @@index([companyId])
  @@index([visibility])
}

model PitchDeckView {
  id         String    @id @default(cuid())
  pitchDeckId String
  pitchDeck  PitchDeck @relation(fields: [pitchDeckId], references: [id], onDelete: Cascade)
  userId     String?
  viewedAt   DateTime  @default(now())

  @@index([pitchDeckId])
  @@index([userId])
}

model DataRoomDocument {
  id          String   @id @default(cuid())
  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  description String?
  fileUrl     String
  fileSize    Int?
  docType     String? // term_sheet | financials | cap_table | product_deck | market_research | other
  visibility  String   @default("invite_only") // public | logged_in | invite_only
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([docType])
}

// ─── Wave 1: Company Announcements ──────────────────────────────────────────

model CompanyAnnouncement {
  id          String         @id @default(cuid())
  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  authorId    String? // the user who posted it (typically claimed owner)
  author      User?          @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  title       String
  body        String         @db.Text
  linkUrl     String?
  category    String?        @default("general") // general | product | hiring | funding | milestone
  pinned      Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([companyId])
  @@index([createdAt])
  @@index([category])
}

// ─── Wave 2: Mission Photo Gallery ──────────────────────────────────────────

model MissionPhoto {
  id            String   @id @default(cuid())
  missionName   String
  missionSlug   String?
  eventId       String? // optional link to SpaceEvent
  companyId     String? // optional company association
  title         String
  description   String?  @db.Text
  photoUrl      String
  thumbnailUrl  String?
  credit        String? // photographer / agency / source
  creditUrl     String?
  takenAt       DateTime?
  tags          String[]
  category      String? // launch | on_orbit | landing | test | infrastructure | crew
  featured      Boolean  @default(false)
  uploadedById  String?
  approved      Boolean  @default(true) // admin moderation
  views         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([missionSlug])
  @@index([eventId])
  @@index([companyId])
  @@index([featured])
  @@index([category])
  @@index([takenAt])
}

// ─── Wave 2: Event RSVP + Ticketing ─────────────────────────────────────────

model EventRSVP {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  user        User     @relation("UserEventRSVPs", fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("going") // going | maybe | not_going | waitlist
  ticketTier  String? // free | paid | vip
  stripeSessionId String?
  paid        Boolean  @default(false)
  amount      Float?
  currency    String?  @default("USD")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

// ─── Wave 2: Mentor Marketplace ─────────────────────────────────────────────

model MentorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  headline        String
  bio             String   @db.Text
  expertiseAreas  String[] // e.g. ["propulsion", "regulatory", "fundraising"]
  yearsExperience Int?
  hourlyRate      Float?
  currency        String?  @default("USD")
  availability    String? // weekly | monthly | project
  remoteOnly      Boolean  @default(true)
  acceptingMentees Boolean @default(true)
  pastCompanies   String[]
  linkedinUrl     String?
  endorsementCount Int     @default(0)
  rating          Float?
  ratingCount     Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matches  MentorMatch[]

  @@index([userId])
  @@index([acceptingMentees])
  @@index([hourlyRate])
}

model MentorMatch {
  id           String        @id @default(cuid())
  mentorId     String
  mentor       MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  menteeUserId String
  message      String        @db.Text
  status       String        @default("pending") // pending | accepted | declined | completed
  respondedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([mentorId])
  @@index([menteeUserId])
  @@index([status])
}

model SkillEndorsement {
  id            String   @id @default(cuid())
  endorserId    String // user doing the endorsing
  endorseeId    String // user being endorsed
  skill         String
  note          String?
  createdAt     DateTime @default(now())

  @@unique([endorserId, endorseeId, skill])
  @@index([endorseeId])
  @@index([skill])
}

// ─── Wave 2: Credentials ────────────────────────────────────────────────────

model UserCredential {
  id               String   @id @default(cuid())
  userId           String
  credentialType   String // degree | certification | clearance | license | patent
  title            String
  issuingOrg       String
  issuedAt         DateTime?
  expiresAt        DateTime?
  credentialId     String? // license number, diploma id, etc.
  verificationUrl  String?
  supportingDocUrl String? // attached evidence
  status           String   @default("self_reported") // self_reported | pending | verified | rejected
  verifiedAt       DateTime?
  verifierId       String? // admin who verified
  rejectionReason  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([credentialType])
}

// ─── Wave 2: Cap Table Transparency ─────────────────────────────────────────

model CapTable {
  id                 String   @id @default(cuid())
  companyId          String   @unique
  currentValuation   Float?
  currency           String?  @default("USD")
  sharesAuthorized   BigInt?
  sharesOutstanding  BigInt?
  asOfDate           DateTime?
  visibility         String   @default("invite_only") // public | logged_in | invite_only
  uploadedByUserId   String?
  documentUrl        String? // optional supporting doc (e.g. Carta export)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  entries CapTableEntry[]
  shares  CapTableShare[]

  @@index([visibility])
}

model CapTableEntry {
  id           String   @id @default(cuid())
  capTableId   String
  capTable     CapTable @relation(fields: [capTableId], references: [id], onDelete: Cascade)
  holderName   String
  holderType   String // founder | employee | investor | other
  shareClass   String // common | preferred_a | preferred_b | convertible | safe | option_pool
  shareCount   BigInt?
  percentage   Float?
  investmentAmount Float?
  roundLabel   String? // seed | series_a | etc.
  acquiredAt   DateTime?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([capTableId])
  @@index([holderType])
  @@index([shareClass])
}

model CapTableShare {
  id           String   @id @default(cuid())
  capTableId   String
  capTable     CapTable @relation(fields: [capTableId], references: [id], onDelete: Cascade)
  grantedToUserId String // user who now has read access
  grantedByUserId String
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([capTableId, grantedToUserId])
  @@index([grantedToUserId])
}

// ─── Wave 2: Corporate Messaging + Teams ────────────────────────────────────

model CorporateChannel {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  channelType String   @default("announcement") // announcement | discussion | project
  visibility  String   @default("members") // public | members | invite_only
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships ChannelMembership[]
  messages    ChannelMessage[]

  @@index([companyId])
  @@index([channelType])
}

model ChannelMembership {
  id         String          @id @default(cuid())
  channelId  String
  channel    CorporateChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String
  role       String          @default("member") // owner | admin | member | readonly
  joinedAt   DateTime        @default(now())
  mutedUntil DateTime?

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelMessage {
  id         String          @id @default(cuid())
  channelId  String
  channel    CorporateChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId   String
  body       String          @db.Text
  parentMessageId String? // threading
  pinned     Boolean         @default(false)
  editedAt   DateTime?
  createdAt  DateTime        @default(now())

  @@index([channelId])
  @@index([authorId])
  @@index([createdAt])
}

model TeamProject {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  ownerId     String
  status      String   @default("active") // active | paused | completed | archived
  dueDate     DateTime?
  memberUserIds String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([ownerId])
  @@index([status])
}

// ─── Wave 2: Podcast Directory + Transcripts ────────────────────────────────

model Podcast {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?  @db.Text
  feedUrl      String?
  websiteUrl   String?
  artworkUrl   String?
  author       String?
  category     String?
  language     String?  @default("en")
  episodeCount Int      @default(0)
  lastFetchedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  episodes PodcastEpisode[]

  @@index([slug])
  @@index([category])
}

model PodcastEpisode {
  id          String   @id @default(cuid())
  podcastId   String
  podcast     Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?  @db.Text
  audioUrl    String?
  durationSec Int?
  publishedAt DateTime?
  episodeNumber Int?
  seasonNumber Int?
  transcript  PodcastTranscript?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([podcastId, slug])
  @@index([podcastId])
  @@index([publishedAt])
}

model PodcastTranscript {
  id         String   @id @default(cuid())
  episodeId  String   @unique
  episode    PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  body       String   @db.Text
  language   String   @default("en")
  generatedBy String? // "whisper" | "manual" | "host"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([episodeId])
}

// ─── Wave 2: Mission Debrief ────────────────────────────────────────────────

model MissionDebrief {
  id             String   @id @default(cuid())
  slug           String   @unique
  eventId        String? // link to SpaceEvent
  missionName    String
  missionDate    DateTime
  status         String // success | partial | failure | scrubbed
  executiveSummary String @db.Text
  timeline       Json? // array of { t, label, note }
  costsEstimate  Float?
  currency       String?  @default("USD")
  companyIds     String[] // involved companies (scalar array)
  keyTakeaways   String[]
  sources        Json? // array of { url, title }
  fullAnalysis   String   @db.Text // AI-generated long-form
  generatedBy    String?  @default("claude") // claude | manual | mixed
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
  @@index([missionDate])
  @@index([status])
}

// ─── Wave 3: Universal Watchlist ────────────────────────────────────────────

model WatchlistItem {
  id         String   @id @default(cuid())
  userId     String
  entityType String // company | person | mission | vehicle | technology | investor | podcast | conference
  entityId   String
  entityLabel String? // denormalized for easy display
  alertLevel String   @default("all") // all | major | none
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
}

// ─── Wave 3: Expert AMAs + Office Hours ─────────────────────────────────────

model ExpertSession {
  id            String   @id @default(cuid())
  hostUserId    String
  sessionType   String // ama | office_hours | workshop | panel
  title         String
  description   String   @db.Text
  scheduledAt   DateTime
  durationMin   Int      @default(60)
  maxAttendees  Int?
  attendeeCount Int      @default(0)
  streamUrl     String?
  recordingUrl  String?
  status        String   @default("scheduled") // scheduled | live | completed | cancelled
  tags          String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  questions SessionQuestion[]
  rsvps     SessionRSVP[]

  @@index([hostUserId])
  @@index([scheduledAt])
  @@index([sessionType])
  @@index([status])
}

model SessionQuestion {
  id         String   @id @default(cuid())
  sessionId  String
  session    ExpertSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  askerId    String
  body       String   @db.Text
  upvotes    Int      @default(0)
  answered   Boolean  @default(false)
  answerText String?  @db.Text
  answeredAt DateTime?
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([upvotes])
}

model SessionRSVP {
  id        String   @id @default(cuid())
  sessionId String
  session   ExpertSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([sessionId, userId])
  @@index([userId])
}

model OfficeHourSlot {
  id           String   @id @default(cuid())
  mentorUserId String
  startTime    DateTime
  endTime      DateTime
  status       String   @default("open") // open | booked | cancelled
  bookedByUserId String?
  topic        String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([mentorUserId])
  @@index([startTime])
  @@index([status])
}

// ─── Wave 3: Satellite Pass Alerts ──────────────────────────────────────────

model SatellitePassAlert {
  id         String   @id @default(cuid())
  userId     String
  satellite  String // ISS | Starlink-XXXX | norad catalog ID
  latitude   Float
  longitude  Float
  locationLabel String?
  minElevation Float  @default(10) // degrees above horizon
  enabled    Boolean  @default(true)
  lastNotifiedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([satellite])
  @@index([enabled])
}

// ─── Wave 3: Countdown Widgets ──────────────────────────────────────────────

model CountdownWidget {
  id           String   @id @default(cuid())
  slug         String   @unique
  missionName  String
  targetTime   DateTime
  eventId      String? // optional SpaceEvent link
  theme        String   @default("dark") // dark | light | minimal | retro
  createdById  String?
  views        Int      @default(0)
  embedsCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
  @@index([targetTime])
}

// ─── Wave 3: Study Groups + Reading Clubs ───────────────────────────────────

model StudyGroup {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  topic       String // orbital-mechanics | space-law | supply-chain | propulsion | etc.
  hostUserId  String
  meetingCadence String? // weekly | biweekly | monthly
  memberLimit Int?
  isPrivate   Boolean  @default(false)
  readingList Json? // array of { title, url, type }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships GroupMembership[]
  meetings    GroupMeeting[]

  @@index([topic])
  @@index([hostUserId])
}

model GroupMembership {
  id        String   @id @default(cuid())
  groupId   String
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("member") // host | member
  joinedAt  DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupMeeting {
  id         String   @id @default(cuid())
  groupId    String
  group      StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title      String
  scheduledAt DateTime
  durationMin Int @default(60)
  streamUrl  String?
  agendaMd   String? @db.Text
  createdAt  DateTime @default(now())

  @@index([groupId])
  @@index([scheduledAt])
}

// ─── Wave 3: Launch Cost Benchmarking + Supplier Reliability ────────────────

model LaunchCostBenchmark {
  id            String   @id @default(cuid())
  vehicle       String
  provider      String
  payloadKg     Float
  orbitType     String // leo | meo | geo | lunar | hyperbolic
  launchDate    DateTime
  costUSD       Float
  costPerKg     Float?
  source        String? // article | filing | press_release
  sourceUrl     String?
  reliability   Float? // success rate for this vehicle as of this date
  notes         String?
  createdAt     DateTime @default(now())

  @@index([vehicle])
  @@index([provider])
  @@index([orbitType])
  @@index([launchDate])
}

model SupplierReliabilityScore {
  id            String   @id @default(cuid())
  companyId     String
  scoredFor     String // overall | propulsion | avionics | comms | structures | launch_services
  onTimePct     Float? // 0-100
  qualityScore  Float? // 0-100
  costPredictabilityScore Float? // 0-100
  overallScore  Float? // 0-100
  sampleSize    Int    @default(0)
  asOfDate      DateTime
  methodology   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, scoredFor, asOfDate])
  @@index([companyId])
  @@index([scoredFor])
}

// ─── Wave 3: Investor Thesis + Deal Memos ───────────────────────────────────

model InvestorThesis {
  id          String   @id @default(cuid())
  slug        String   @unique
  authorUserId String
  title       String
  summary     String   @db.Text
  bodyMd      String   @db.Text
  sectors     String[] // ["launch", "in-space-manufacturing"]
  stagePreference String? // pre-seed | seed | series_a | growth
  geography   String?
  publishedAt DateTime?
  views       Int      @default(0)
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorUserId])
  @@index([publishedAt])
}

model DealMemo {
  id           String   @id @default(cuid())
  slug         String   @unique
  authorUserId String
  companyName  String
  companyId    String? // optional link to CompanyProfile
  dealStage    String // seed | series_a | etc.
  investmentAmount Float?
  currency     String? @default("USD")
  thesis       String   @db.Text
  risks        String?  @db.Text
  recommendation String // invest | pass | more_info
  visibility   String   @default("logged_in") // public | logged_in | private
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([authorUserId])
  @@index([visibility])
  @@index([publishedAt])
}

// ─── Wave 3: This Day in Space ──────────────────────────────────────────────

model SpaceHistoryEvent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String   @db.Text
  eventDate   DateTime // full date for sorting
  monthDay    String // "MM-DD" for "this day" lookups
  year        Int
  category    String // launch | landing | mission | discovery | policy | milestone
  imageUrl    String?
  sourceUrls  String[]
  relatedCompanyIds String[]
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([monthDay])
  @@index([year])
  @@index([category])
  @@index([featured])
}

// ─── Wave 3: Ticket Resale ──────────────────────────────────────────────────

model TicketListing {
  id            String   @id @default(cuid())
  rsvpId        String?  @unique // link to original RSVP being resold
  eventId       String
  sellerUserId  String
  ticketTier    String?
  askingPrice   Float
  currency      String   @default("USD")
  originalPrice Float?
  status        String   @default("listed") // listed | sold | cancelled | expired
  buyerUserId   String?
  soldAt        DateTime?
  sellerRating  Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([eventId])
  @@index([sellerUserId])
  @@index([status])
}

model ResaleTransaction {
  id            String   @id @default(cuid())
  ticketListingId String
  buyerUserId   String
  sellerUserId  String
  amount        Float
  currency      String   @default("USD")
  platformFee   Float    @default(0)
  stripePaymentIntentId String?
  status        String   @default("pending") // pending | completed | refunded
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ticketListingId])
  @@index([buyerUserId])
  @@index([sellerUserId])
}

// ─── Wave 3: Learning Zone ──────────────────────────────────────────────────

model CourseModule {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String   @db.Text
  track        String // orbital-mechanics | propulsion | space-law | supply-chain | communications | kids
  level        String @default("beginner") // beginner | intermediate | advanced
  estimatedMinutes Int?
  heroImageUrl String?
  published    Boolean  @default(false)
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lessons Lesson[]

  @@index([track])
  @@index([published])
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  bodyMd      String   @db.Text
  videoUrl    String?
  interactiveType String? // calculator | simulator | quiz | none
  interactiveConfig Json?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([moduleId, slug])
  @@index([moduleId])
}

model BuildGuide {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String   @db.Text
  track        String // diy-satellite | cansat | high-altitude-balloon | weather-station | amateur-radio
  difficulty   String   @default("intermediate")
  estimatedHours Int?
  materialsList Json? // array of { name, qty, url? }
  steps        Json // array of { title, body, imageUrl? }
  authorUserId String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([track])
  @@index([published])
}
