# ============================================================
# SpaceNexus — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

# ============================================================
# Database (Required)
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/spacenexus

# ============================================================
# NextAuth (Required)
# ============================================================
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# Email — Resend (Required for auth flows & notifications)
# ============================================================
RESEND_API_KEY=re_xxxxx
ADMIN_EMAIL=admin@yourdomain.com
EMAIL_FROM="SpaceNexus <noreply@spacenexus.us>"
NEWSLETTER_FROM_EMAIL="SpaceNexus <noreply@spacenexus.us>"
NEWSLETTER_REPLY_TO=reply@yourdomain.com

# ============================================================
# AI Features (Optional — degrades gracefully without)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============================================================
# Payments — Stripe (Optional — payment features disabled without)
# ============================================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxxxx
STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxxxx
STRIPE_PRICE_SPONSOR_VERIFIED_MONTHLY=price_xxxxx
STRIPE_PRICE_SPONSOR_VERIFIED_YEARLY=price_xxxxx
STRIPE_PRICE_SPONSOR_PREMIUM_MONTHLY=price_xxxxx
STRIPE_PRICE_SPONSOR_PREMIUM_YEARLY=price_xxxxx

# ============================================================
# External Data APIs (Optional — fallback/demo data used without)
# ============================================================
NASA_API_KEY=DEMO_KEY
N2YO_API_KEY=
FINNHUB_API_KEY=
SAM_GOV_API_KEY=
SAM_API_KEY=
GITHUB_TOKEN=
METALS_DEV_API_KEY=

# ============================================================
# Push Notifications — Apple APNS (Optional)
# ============================================================
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=

# ============================================================
# Internal / Cron
# ============================================================
CRON_SECRET=generate-a-random-secret-here
# PORT=3000  # Uncomment to override the default port

# ============================================================
# Public / Client-Side
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# ============================================================
# Analytics & SEO (Optional)
# ============================================================
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ============================================================
# Build Options
# ============================================================
# ANALYZE=true  # Uncomment to run bundle analyzer
